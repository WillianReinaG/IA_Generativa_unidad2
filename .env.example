OPENAI_API_KEY=sk-tu-clave-aqui

# Modelo para la API Responses (quickstart OpenAI). Si no tienes acceso, usa Chat Completions:
# ECOMARKET_USE_RESPONSES_API=false
# y opcionalmente ECOMARKET_CHAT_FALLBACK_MODEL=gpt-4o-mini
ECOMARKET_OPENAI_MODEL=gpt-5-nano

# Almacenar respuestas en el proyecto OpenAI (como en el ejemplo de la plataforma)
ECOMARKET_OPENAI_STORE=true

# Solo si Responses falla o quieres forzar el modo clásico:
# ECOMARKET_USE_RESPONSES_API=false
# ECOMARKET_CHAT_FALLBACK_MODEL=gpt-4o-mini
